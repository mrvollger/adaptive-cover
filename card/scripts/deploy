#!/usr/bin/env bash

# Deploy adaptive-cover-card to a Home Assistant server via SMB.
#
# Usage:
#   ./scripts/deploy [--dry-run] [--verbose] [--help]
#
# Flags:
#   --dry-run   Simulate deploy without copying files
#   --verbose   Show bash trace (set -x)
#   --help      Show help and exit
#
# Environment variables (or set in .deploy config file):
#   HA_SMB_HOST   SMB hostname or IP (default: home-assistant.home)
#   HA_SMB_SHARE  SMB share name (default: config)
#   HA_SMB_USER   SMB username (optional; omit for guest access)
#   HA_SMB_PASS   SMB password (optional)
#   HA_URL        Home Assistant URL (default: http://home-assistant.home:8123)
#   HA_TOKEN      Long-lived access token (optional; prompted if not set)

set -e

cd "$(dirname "$0")/.."

# ── Load config file ─────────────────────────────────────────────────────────
# Copy .deploy.example to .deploy and fill in your values (file is .gitignored)
if [[ -f ".deploy" ]]; then
    # shellcheck source=/dev/null
    source ".deploy"
fi

HA_SMB_HOST="${HA_SMB_HOST:-home-assistant.home}"
HA_SMB_SHARE="${HA_SMB_SHARE:-config}"
DRY_RUN=false
VERBOSE=false
MOUNTED_BY_US=false

for arg in "$@"; do
    case "$arg" in
        --dry-run)    DRY_RUN=true ;;
        --verbose|-v) VERBOSE=true ;;
        --help|-h)
            cat <<'HELP'
Usage: ./scripts/deploy [--dry-run] [--verbose] [--help]

Flags:
  --dry-run   Simulate deploy without copying files
  --verbose   Show bash trace (set -x)
  --help      Show this help message and exit

Environment variables (or set in .deploy config file):
  HA_SMB_HOST   SMB hostname or IP  (default: home-assistant.home)
  HA_SMB_SHARE  SMB share name      (default: config)
  HA_SMB_USER   SMB username        (optional; omit for guest access)
  HA_SMB_PASS   SMB password        (optional)
  HA_URL        Home Assistant URL  (default: http://home-assistant.home:8123)
  HA_TOKEN      Long-lived access token (optional; prompted if not set)
HELP
            exit 0
            ;;
    esac
done

if $VERBOSE; then
    set -x
fi

if $DRY_RUN; then
    echo "==> Dry run mode — no files will be copied"
fi

# ── Compute dev version ───────────────────────────────────────────────────────
# Carry the 7-char commit sha as SemVer build metadata on the card's real
# version (e.g. 2.9.0+873727b) so the deployed version stays a valid SemVer that
# shows both the release it's based on and the exact commit.
BASE_VERSION="$(sed -n "s/.*CARD_VERSION = '\([^']*\)'.*/\1/p" src/const.ts | head -1)"
BASE_VERSION="${BASE_VERSION%%+*}"   # strip any prior build metadata
GIT_HASH="$(git rev-parse --short=7 HEAD 2>/dev/null || echo "unknown")"
DEV_SHA="${GIT_HASH}"
IS_DIRTY=false
if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
    IS_DIRTY=true
    DEV_SHA="${DEV_SHA}.dirty"
fi

# For dirty builds, append an incrementing counter persisted in .dirty-deploy
# (gitignored) so repeated deploys of the same dirty tree get unique versions —
# the Lovelace resource URL below is cache-busted on this version.
_DIRTY_N=""
if $IS_DIRTY; then
    _DIRTY_N=1
    if [[ -f ".dirty-deploy" ]]; then
        IFS=: read -r _SAVED_HASH _SAVED_N < ".dirty-deploy"
        if [[ "$_SAVED_HASH" == "$GIT_HASH" ]]; then
            _DIRTY_N="${_SAVED_N:-1}"
        fi
    fi
    DEV_SHA="${DEV_SHA}.${_DIRTY_N}"
fi

DEV_VERSION="${BASE_VERSION}+${DEV_SHA}"

# ── Cleanup on exit ──────────────────────────────────────────────────────────
cleanup() {
    if [[ -n "${ORIGINAL_CONST:-}" ]]; then
        echo "$ORIGINAL_CONST" > src/const.ts
    fi
    # Restore the pre-deploy dist bundle so the working tree is left exactly as
    # we found it. We can't `git checkout` here: that resets dist to HEAD and
    # would silently discard a legitimate uncommitted build (e.g. a freshly
    # rebuilt bundle on a feature branch). Restoring the backed-up file only
    # undoes the dev-version stamp this script introduced.
    if [[ -n "${DIST_BAK:-}" && -f "$DIST_BAK" ]]; then
        mv -f "$DIST_BAK" dist/adaptive-cover-card.js
    fi
    if $MOUNTED_BY_US && [[ -n "${MOUNT_POINT:-}" ]]; then
        if mount | grep -q "on ${MOUNT_POINT} "; then
            echo "==> Unmounting ${MOUNT_POINT}..."
            case "$(uname)" in
                Darwin)
                    diskutil unmount force "${MOUNT_POINT}" 2>/dev/null || umount "${MOUNT_POINT}" 2>/dev/null || true
                    ;;
                *)
                    sudo umount "${MOUNT_POINT}" 2>/dev/null || umount "${MOUNT_POINT}" 2>/dev/null || true
                    ;;
            esac
        fi
        rmdir "${MOUNT_POINT}" 2>/dev/null || true
    fi
}

# ── Build with dev version stamped into CARD_VERSION ─────────────────────────
ORIGINAL_CONST="$(cat src/const.ts)"
# Back up the current dist bundle so cleanup() can restore the working tree to
# its exact pre-deploy state — the build below overwrites it with a dev-stamped
# copy, and we don't want that (or any uncommitted dist) left behind.
DIST_BAK=""
if [[ -f dist/adaptive-cover-card.js ]]; then
    DIST_BAK="$(mktemp)"
    cp dist/adaptive-cover-card.js "$DIST_BAK"
fi
trap cleanup EXIT
# Portable sed -i: -i.bak works on both GNU (Linux) and BSD (macOS) sed.
sed -i.bak "s/export const CARD_VERSION = '.*'/export const CARD_VERSION = '${DEV_VERSION}'/" src/const.ts
rm -f src/const.ts.bak
echo "==> Building (version ${DEV_VERSION})"
npm run build
echo "$ORIGINAL_CONST" > src/const.ts
ORIGINAL_CONST=""  # disarm cleanup restore

# ── Build SMB URL (macOS mount_smbfs form) ───────────────────────────────────
if [[ -n "${HA_SMB_USER:-}" ]]; then
    PASS_PART=""
    if [[ -n "${HA_SMB_PASS:-}" ]]; then
        PASS_PART=":${HA_SMB_PASS}"
    fi
    SMB_URL="//${HA_SMB_USER}${PASS_PART}@${HA_SMB_HOST}/${HA_SMB_SHARE}"
else
    SMB_URL="//${HA_SMB_HOST}/${HA_SMB_SHARE}"
fi

# Pick the mount command based on OS. macOS uses mount_smbfs; Linux uses
# mount.cifs (from cifs-utils). On Linux the mount syscall needs root, so we
# call it via sudo — configure passwordless sudo for mount.cifs if you want
# this fully hands-off. Pre-mounting manually also works; the existing-mount
# check below reuses an existing mount and skips this entirely.
do_mount() {
    local mount_point="$1"
    case "$(uname)" in
        Darwin)
            if $VERBOSE; then
                mount_smbfs "${SMB_URL}" "${mount_point}"
            else
                mount_smbfs "${SMB_URL}" "${mount_point}" 2>/dev/null
            fi
            ;;
        Linux)
            if ! command -v mount.cifs >/dev/null 2>&1; then
                echo "    mount.cifs not found — install cifs-utils (sudo apt install cifs-utils)" >&2
                return 1
            fi
            local opts="uid=$(id -u),gid=$(id -g)"
            if [[ -n "${HA_SMB_USER:-}" ]]; then
                opts="${opts},username=${HA_SMB_USER}"
                if [[ -n "${HA_SMB_PASS:-}" ]]; then
                    opts="${opts},password=${HA_SMB_PASS}"
                fi
            else
                opts="${opts},guest"
            fi
            sudo mount -t cifs "//${HA_SMB_HOST}/${HA_SMB_SHARE}" "${mount_point}" -o "${opts}"
            ;;
        *)
            echo "    Unsupported OS: $(uname)" >&2
            return 1
            ;;
    esac
}

# ── Mount (reuse existing mount if present) ───────────────────────────────────
EXISTING_MOUNT="$(mount | grep -i "${HA_SMB_HOST}/${HA_SMB_SHARE}" | awk '{print $3}' | head -1)"
if [[ -n "$EXISTING_MOUNT" ]]; then
    echo "==> Share already mounted at ${EXISTING_MOUNT}, reusing it."
    MOUNT_POINT="$EXISTING_MOUNT"
else
    MOUNT_POINT="$(mktemp -d)"
    MOUNTED_BY_US=true
    echo "==> Mounting //${HA_SMB_HOST}/${HA_SMB_SHARE} → ${MOUNT_POINT}..."
    do_mount "${MOUNT_POINT}" || true
    if ! mount | grep -q "on ${MOUNT_POINT} "; then
        echo "    First mount attempt failed; trying with credentials..."
        read -r -p "    SMB username: " HA_SMB_USER
        read -r -s -p "    SMB password: " HA_SMB_PASS
        echo
        export HA_SMB_USER HA_SMB_PASS
        do_mount "${MOUNT_POINT}"
    fi
fi

# ── Deploy ───────────────────────────────────────────────────────────────────
SRC="dist/adaptive-cover-card.js"
DST_DIR="${MOUNT_POINT}/www/community/adaptive-cover-card"
DST="${DST_DIR}/adaptive-cover-card.js"

echo "==> Deploying ${SRC} → ${DST}..."

if $DRY_RUN; then
    GZ_FILES=$(find "${DST_DIR}" -maxdepth 1 -name '*.gz' 2>/dev/null)
    if [[ -n "$GZ_FILES" ]]; then
        echo "==> Would delete: $GZ_FILES"
    fi
    echo ""
    echo "==> Dry run complete — no files were copied."
else
    mkdir -p "${DST_DIR}"
    # Remove any stale gzip-compressed copies HACS may have left behind.
    find "${DST_DIR}" -maxdepth 1 -name '*.gz' -delete
    cp "${SRC}" "${DST}"

    echo ""
    echo "==> Deploy complete (version ${DEV_VERSION})."

    # ── Persist the dirty-build deploy counter ────────────────────────────────
    if $IS_DIRTY; then
        echo "${GIT_HASH}:$((_DIRTY_N + 1))" > ".dirty-deploy"
    fi

    # ── Bump Lovelace resource URL so HA serves the new bundle ───────────────
    HA_URL="${HA_URL:-http://home-assistant.home:8123}"
    if [[ -z "${HA_TOKEN:-}" ]]; then
        read -r -p "==> Long-lived access token (for resource URL bump): " HA_TOKEN
    fi

    NEW_URL="/hacsfiles/adaptive-cover-card/adaptive-cover-card.js?v=${DEV_VERSION}"

    BUMP_RESULT=$(/usr/bin/python3 - "${HA_URL}" "${HA_TOKEN}" "${NEW_URL}" <<'PYEOF'
import socket, json, struct, os, sys, base64

ha_url, token, new_url = sys.argv[1], sys.argv[2], sys.argv[3]
host_port = ha_url.replace('http://','').replace('https://','')
host = host_port.split(':')[0]
port = int(host_port.split(':')[1]) if ':' in host_port else 8123

try:
    sock = socket.create_connection((host, port), timeout=10)
except OSError as e:
    print(f'CONNFAIL:{e}'); sys.exit(0)

key = base64.b64encode(os.urandom(16)).decode()
sock.sendall((
    f'GET /api/websocket HTTP/1.1\r\nHost: {host}:{port}\r\n'
    'Upgrade: websocket\r\nConnection: Upgrade\r\n'
    f'Sec-WebSocket-Key: {key}\r\nSec-WebSocket-Version: 13\r\n\r\n'
).encode())
buf = b''
while b'\r\n\r\n' not in buf:
    buf += sock.recv(1)

def ws_recv():
    h = sock.recv(2); ln = h[1] & 0x7f
    if ln == 126: ln = struct.unpack('>H', sock.recv(2))[0]
    elif ln == 127: ln = struct.unpack('>Q', sock.recv(8))[0]
    data = b''
    while len(data) < ln: data += sock.recv(ln - len(data))
    return json.loads(data)

def ws_send(msg):
    data = json.dumps(msg).encode(); mask = os.urandom(4)
    masked = bytes(b ^ mask[i % 4] for i, b in enumerate(data)); ln = len(data)
    header = (bytes([0x81, 0x80 | ln]) + mask if ln < 126
              else bytes([0x81, 0xfe]) + struct.pack('>H', ln) + mask)
    sock.sendall(header + masked)

ws_recv()  # auth_required
ws_send({'type': 'auth', 'access_token': token})
if ws_recv().get('type') != 'auth_ok':
    print('AUTHFAIL'); sys.exit(0)

ws_send({'id': 1, 'type': 'lovelace/resources/list'})
resources = ws_recv().get('result', [])
match = next((r for r in resources if 'adaptive-cover-card' in r.get('url', '')), None)
if match:
    ws_send({'id': 2, 'type': 'lovelace/resources/update',
             'resource_id': match['id'], 'res_type': 'module', 'url': new_url})
    print('OK' if ws_recv().get('success') else 'UPDATEFAIL')
else:
    ws_send({'id': 2, 'type': 'lovelace/resources/create',
             'res_type': 'module', 'url': new_url})
    print('CREATED' if ws_recv().get('success') else 'CREATEFAIL')
sock.close()
PYEOF
    )

    case "$BUMP_RESULT" in
        OK)
            echo "==> Resource URL updated — reload the dashboard tab."
            ;;
        CREATED)
            echo "==> Resource created — reload the dashboard tab."
            ;;
        CREATEFAIL)
            echo "==> Could not create resource — add it manually in Settings → Dashboards → Resources:"
            echo "    ${NEW_URL}"
            ;;
        AUTHFAIL)
            echo "==> HA token rejected — check HA_TOKEN in .deploy."
            echo "    Update the resource URL manually to: ${NEW_URL}"
            ;;
        CONNFAIL:*)
            echo "==> Could not reach HA at ${HA_URL} — ${BUMP_RESULT#CONNFAIL:}"
            echo "    Check HA_URL in .deploy, then update the resource URL manually to:"
            echo "    ${NEW_URL}"
            ;;
        *)
            echo "==> Resource URL bump failed — update manually to: ${NEW_URL}"
            ;;
    esac
fi
